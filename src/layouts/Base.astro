---
import '../styles/global.css';
import { ADSENSE_CLIENT } from '../consts';

interface Props {
  title: string;
  description: string;
  ogType?: string;
}

const { title, description, ogType = 'website' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/ogp.png', Astro.site);
const siteName = 'yohakulab';
const fullTitle = Astro.url.pathname === '/' ? `${siteName}｜シンプルなアプリと、余白のある暮らし。` : `${title}｜${siteName}`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@yohakulab_app" />
    <meta name="generator" content={Astro.generator} />
    {
      ADSENSE_CLIENT && (
        <script
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT}`}
          crossorigin="anonymous"
        />
      )
    }
  </head>
  <body>
    <header class="site-header">
      <div class="inner">
        <a href="/" class="brand" aria-label="yohakulab トップページ">
          <svg width="26" height="26" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="400" height="400" rx="80" fill="#1e293b"/>
            <rect x="104" y="104" width="88" height="88" rx="22" fill="#2dd4be"/>
            <rect x="208" y="104" width="88" height="88" rx="22" fill="#fbbf24"/>
            <rect x="104" y="208" width="88" height="88" rx="22" fill="#818cf8"/>
            <rect x="208" y="208" width="88" height="88" rx="22" fill="none" stroke="#475569" stroke-width="8" stroke-dasharray="14 12"/>
          </svg>
          <span>yohakulab</span>
        </a>
        <nav class="site-nav">
          <a href="/blog/">ブログ</a>
          <a href="/apps/">アプリ</a>
          <a href="/about/">About</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="inner">
        <nav>
          <a href="/about/">運営者情報</a>
          <a href="/contact/">お問い合わせ</a>
          <a href="/privacy/">プライバシーポリシー</a>
          <a href="/disclaimer/">免責事項</a>
          <a href="https://x.com/yohakulab_app" rel="noopener" target="_blank">X (@yohakulab_app)</a>
        </nav>
        <div class="copyright">© {new Date().getFullYear()} yohakulab</div>
      </div>
    </footer>
  </body>
</html>
