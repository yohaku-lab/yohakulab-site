---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latest = posts.slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base
  title="yohakulab"
  description="シンプルなアプリと、余白のある暮らし。登録不要で使える無料の家計・資産ツールと、FIRE・お金にまつわる検証記事を公開しています。"
>
  <section class="hero">
    <svg class="tiles" width="72" height="72" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect width="400" height="400" rx="80" fill="#1e293b"/>
      <rect x="104" y="104" width="88" height="88" rx="22" fill="#2dd4be"/>
      <rect x="208" y="104" width="88" height="88" rx="22" fill="#fbbf24"/>
      <rect x="104" y="208" width="88" height="88" rx="22" fill="#818cf8"/>
      <rect x="208" y="208" width="88" height="88" rx="22" fill="none" stroke="#475569" stroke-width="8" stroke-dasharray="14 12"/>
    </svg>
    <h1>シンプルなアプリと、<br />余白のある暮らし。</h1>
    <p class="lead">
      yohakulab（余白ラボ）は、登録不要・無料で使えるシンプルなWebアプリと、
      お金と暮らしにまつわる検証記事をつくる個人ラボです。
    </p>
  </section>

  <section id="apps">
    <h2>アプリ</h2>
    <div class="card-grid">
      <a class="card" href="https://fire.yohakulab.app/">
        <span class="card-tag">資産シミュレーション</span>
        <h3>シンプルFIRE計画</h3>
        <p>
          積立でいつ目標に届くか、資産が何歳まで持つかをモンテカルロシミュレーションで確率表示。登録不要・ブラウザ内で完結。
        </p>
      </a>
      <a class="card" href="https://seisan.yohakulab.app/">
        <span class="card-tag">日々のお金</span>
        <h3>シンプル生活費精算</h3>
        <p>
          2人の立て替えをその場で精算。比率指定にも対応した、余計な機能のない精算アプリ。
        </p>
      </a>
      <a class="card" href="https://keisha.yohakulab.app/">
        <span class="card-tag">日々のお金</span>
        <h3>シンプル傾斜割り勘</h3>
        <p>
          メンバーごとに比率を変えて傾斜配分。上限・下限・丸め単位もまとめて指定できる割り勘計算ツール。登録不要。
        </p>
      </a>
      <a class="card" href="https://keiro.yohakulab.app/">
        <span class="card-tag">おでかけ</span>
        <h3>シンプル経路比較</h3>
        <p>
          乗換案内アプリの共有テキストを貼り付けるだけで、複数の経路を1画面で並べて比較。登録不要・広告なし。
        </p>
      </a>
    </div>
  </section>

  <section>
    <h2>最新記事</h2>
    <ul class="post-list">
      {
        latest.map((post) => (
          <li>
            <a class="card" href={`/blog/${post.id}/`}>
              <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
            </a>
          </li>
        ))
      }
    </ul>
    <p class="section-more"><a href="/blog/">記事一覧へ →</a></p>
  </section>
</Base>
