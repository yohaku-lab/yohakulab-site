---
/**
 * 生存率カーブ：年齢（横軸）ごとの「まだ資産が残っている確率」を面＋線で描く。
 * 「失敗は突然来ない、じわじわ下がる」ことを直感的に見せる。ビルド時に静的SVG化（JSなし）。
 *
 * data: [age, survivalPercent][]
 * annotations: 少数のキーポイントに直接ラベルを置く（例：60歳時点で87%）
 */
interface Annotation {
  age: number;
  text?: string;
  anchor?: 'start' | 'middle' | 'end';
  dy?: number;
}
interface Props {
  title?: string;
  caption?: string;
  data: number[][];
  annotations?: Annotation[];
}

const { title, caption, data, annotations = [] } = Astro.props;

const ages = data.map((r) => r[0]);
const minAge = Math.min(...ages);
const maxAge = Math.max(...ages);
const xTicks = ages.filter((a) => a % 10 === 0);
const yTicks = [0, 25, 50, 75, 100];

const W = 640, H = 260, ML = 46, MR = 14, MT = 14, MB = 30;
const plotW = W - ML - MR, plotH = H - MT - MB;
const px = (age: number) => ML + ((age - minAge) / (maxAge - minAge)) * plotW;
const py = (p: number) => MT + plotH - (p / 100) * plotH;

const valueAt = (age: number) => {
  const row = data.reduce((closest, r) => (Math.abs(r[0] - age) < Math.abs(closest[0] - age) ? r : closest), data[0]);
  return row[1];
};

const linePts = data.map((r) => `${px(r[0]).toFixed(1)},${py(r[1]).toFixed(1)}`).join(' ');
const areaPts = `${linePts} ${px(maxAge).toFixed(1)},${py(0).toFixed(1)} ${px(minAge).toFixed(1)},${py(0).toFixed(1)}`;
---

<figure class="chart survival-chart">
  {title && <figcaption class="chart-title">{title}</figcaption>}
  <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-label={title ?? '年齢ごとに資産が残っている確率の推移'}>
    {yTicks.map((t) => (
      <>
        <line x1={ML} y1={py(t)} x2={W - MR} y2={py(t)} class="grid" />
        <text x={ML - 8} y={py(t) + 4} class="tick" text-anchor="end">{t}%</text>
      </>
    ))}
    {xTicks.map((t) => (
      <text x={px(t)} y={H - 8} class="tick" text-anchor="middle">{t}歳</text>
    ))}
    <polygon points={areaPts} class="area" />
    <polyline points={linePts} class="line" />
    {annotations.map((a) => {
      const v = valueAt(a.age);
      return (
        <>
          <circle cx={px(a.age)} cy={py(v)} r="4" class="dot" />
          <text
            x={px(a.age)}
            y={py(v) + (a.dy ?? -10)}
            text-anchor={a.anchor ?? 'middle'}
            class="note ink"
          >
            {a.text ?? `${Math.round(v)}%`}
          </text>
        </>
      );
    })}
  </svg>
  {caption && <p class="chart-caption">{caption}</p>}
  <details class="chart-table">
    <summary>年齢ごとの数値を表で見る</summary>
    <table>
      <thead>
        <tr><th>年齢</th><th>資産が残っている確率</th></tr>
      </thead>
      <tbody>
        {data.filter((r) => r[0] % 10 === 0).map((r) => (
          <tr>
            <td>{r[0]}歳</td>
            <td>{Math.round(r[1] * 10) / 10}%</td>
          </tr>
        ))}
      </tbody>
    </table>
  </details>
</figure>

<style>
  .chart {
    margin: 2rem 0;
    padding: 1.4rem 1.5rem 1.5rem;
    background: #fbfcfd;
    border: 1px solid var(--border);
    border-radius: 14px;
  }
  .chart-title {
    font-weight: 700;
    color: var(--navy);
    font-size: 0.98rem;
    line-height: 1.5;
    margin-bottom: 1rem;
  }
  svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .grid {
    stroke: #e6ebf1;
    stroke-width: 1;
  }
  .tick {
    font-size: 11px;
    fill: var(--text-muted);
  }
  .area {
    fill: rgba(15, 158, 140, 0.12);
  }
  .line {
    fill: none;
    stroke: var(--teal-dark);
    stroke-width: 2.5;
    stroke-linejoin: round;
    stroke-linecap: round;
  }
  .dot {
    fill: var(--teal-dark);
    stroke: #fbfcfd;
    stroke-width: 2;
  }
  .note {
    font-size: 11px;
    fill: var(--text-muted);
  }
  .note.ink {
    fill: var(--teal-dark);
    font-weight: 700;
  }
  .chart-caption {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin: 0.9rem 0 0;
    line-height: 1.6;
  }
  .chart-table {
    margin-top: 0.9rem;
    font-size: 0.82rem;
  }
  .chart-table summary {
    cursor: pointer;
    color: var(--teal-dark);
    font-weight: 600;
  }
  .chart-table table {
    margin: 0.8rem 0 0 !important;
  }
</style>
